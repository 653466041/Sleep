<view class="page">
  <view class="top-bar">
    <view class="back-button" bindtap="onBackTap" aria-label="返回">
      <text class="material-icon">arrow_back</text>
    </view>
    <text class="title">{{pageTitle}}</text>
    <view class="top-spacer"></view>
  </view>

  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="track-list">
      <view
        wx:for="{{tracks}}"
        wx:key="id"
        class="track-card {{item.active ? 'track-card-active' : ''}}"
        bindtap="onTrackTap"
        data-id="{{item.id}}"
      >
        <view class="track-icon">
          <text class="material-icon track-symbol">{{item.icon}}</text>
        </view>
        <view class="track-copy">
          <text class="track-title">{{item.title}}</text>
          <text class="track-meta">{{item.meta}}</text>
        </view>
        <view class="track-action">
          <view wx:if="{{item.active}}" class="action-symbol pause-symbol"></view>
          <view wx:else class="action-symbol play-symbol"></view>
        </view>
      </view>
    </view>

    <view class="scroll-bottom-space"></view>
  </scroll-view>

  <view class="mini-player">
    <view class="mini-player-card" bindtap="onMiniPlayerTap">
      <view class="mini-left">
        <view class="mini-icon">
          <text class="material-icon mini-symbol">{{miniIcon}}</text>
        </view>
        <view class="mini-copy">
          <text class="mini-title">{{miniTitle}}</text>
          <text class="mini-status">{{miniStatus}}</text>
        </view>
      </view>

      <view class="mini-actions">
        <view class="mini-action" catchtap="onTimerTap" aria-label="定时">
          <text class="material-icon timer-symbol">schedule</text>
        </view>
        <view class="mini-action mini-action-primary" catchtap="onPauseTap" aria-label="暂停">
          <view wx:if="{{miniPlaying}}" class="mini-pause-symbol"></view>
          <view wx:else class="mini-play-symbol"></view>
        </view>
      </view>
    </view>
  </view>
</view>
